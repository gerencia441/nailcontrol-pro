# Database
# Example MySQL URL: mysql://user:password@host:3306/dbname
DATABASE_URL="mysql://dbuser:dbpass@localhost:3306/nailcontrol"

# Optional shadow DB used by Prisma Migrate
SHADOW_DATABASE_URL="mysql://dbuser:dbpass@localhost:3306/nailcontrol_shadow"

# JWT secret for auth
JWT_SECRET="cambia_esto_por_un_valor_seguro"

# Server
# PORT is optional (default 3001)
PORT=3001
NODE_ENV=development

# Frontend URL (used for OAuth redirect back)
FRONTEND_URL="http://localhost:5174"

# Google OAuth (only if vas a integrar Google Calendar)
# Create credentials in Google Cloud Console (OAuth Client ID, type: Web application)
# Set the redirect URI in Google Cloud to: http://localhost:3001/api/integrations/google/callback
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"
GOOGLE_REDIRECT="http://localhost:3001/api/integrations/google/callback"

# --- NOTES ---
# 1) Copia este archivo a `.env` en la carpeta `server` y reemplaza los valores.
# 2) No subas `.env` al repositorio.
# 3) Antes de ejecutar migraciones, asegúrate de que DATABASE_URL y SHADOW_DATABASE_URL sean válidas.