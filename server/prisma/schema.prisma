generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String        @id @default(cuid())
  name           String
  birthDate      DateTime?
  phone          String?
  tags           String        @db.LongText
  technicalNotes String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
}

model Service {
  id           String               @id @default(cuid())
  name         String
  basePrice    Float
  durationMinutes Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  appointments AppointmentService[]
}

model Manicurist {
  id                   String        @id @default(cuid())
  name                 String
  phone                String?
  commissionPercentage Float
  color                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments         Appointment[]
}

model Appointment {
  id                 String               @id @default(cuid())
  clientId           String
  manicuristId       String
  date               DateTime
  status             AppointmentStatus    @default(PENDING)
  confirmed          Boolean              @default(false)
  finalPricePaid     Float?
  paymentMethod      PaymentMethod?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  googleEventId      String?
  client             Client               @relation(fields: [clientId], references: [id])
  manicurist         Manicurist           @relation(fields: [manicuristId], references: [id])
  services           AppointmentService[]

  @@index([clientId], map: "Appointment_clientId_fkey")
  @@index([manicuristId], map: "Appointment_manicuristId_fkey")
}

model Finance {
  id                   String         @id @default(cuid())
  type                 FinanceType
  amount               Float
  description          String
  date                 DateTime
  paymentMethod        PaymentMethod?
  manicuristColor      String?
  manicuristId         String?
  isCommission         Boolean        @default(false)
  commissionPercentage Float?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model AppointmentService {
  appointmentId String
  serviceId     String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
  @@index([serviceId], map: "AppointmentService_serviceId_fkey")
}

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  password           String
  role               UserRole  @default(MANICURIST)
  manicuristId       String?   @unique
  googleRefreshToken String?
  googleCalendarId   String?
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANCOLOMBIA
  NEQUI
}

enum FinanceType {
  INCOME
  EXPENSE
}

enum UserRole {
  ADMIN
  MANICURIST
}

model Setting {
  key   String @id
  value String @db.Text
}
