generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String        @id @default(cuid())
  name           String
  birthDate      DateTime?
  phone          String?
  tags           String        @db.LongText
  technicalNotes String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
}

model Service {
  id                 String               @id @default(cuid())
  name               String
  basePrice          Float
  durationMinutes    Int
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  AppointmentService AppointmentService[]
}

model Manicurist {
  id                   String        @id @default(cuid())
  name                 String
  phone                String?
  commissionPercentage Float
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments         Appointment[]
}

model Appointment {
  id                 String               @id @default(cuid())
  clientId           String
  manicuristId       String
  date               DateTime
  status             AppointmentStatus    @default(PENDING)
  finalPricePaid     Float?
  paymentMethod      PaymentMethod?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  googleEventId      String?
  client             Client               @relation(fields: [clientId], references: [id])
  manicurist         Manicurist           @relation(fields: [manicuristId], references: [id])
  AppointmentService AppointmentService[]

  @@index([clientId], map: "Appointment_clientId_fkey")
  @@index([manicuristId], map: "Appointment_manicuristId_fkey")
}

model Finance {
  id            String         @id @default(cuid())
  type          FinanceType
  amount        Float
  description   String
  date          DateTime
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AppointmentService {
  appointmentId String
  serviceId     String
  Appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  Service       Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
  @@index([serviceId], map: "AppointmentService_serviceId_fkey")
}

model User {
  id                 String  @id
  username           String  @unique
  password           String
  googleRefreshToken String?
  googleCalendarId   String?
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANCOLOMBIA
  NEQUI
}

enum FinanceType {
  INCOME
  EXPENSE
}
